#include <stdio.h>

int main() 
{
    int consumer_no;
    char name[50];
    float units, bill = 0, fixed_charge = 100;

    printf("----- ELECTRICAL MANAGEMENT SYSTEM -----\n");

    printf("Enter Consumer Number: ");
    scanf("%d", &consumer_no);

    printf("Enter Consumer Name: ");
    scanf("%s", name);

    printf("Enter Units Consumed: ");
    scanf("%f", &units);

    if (units <= 100)
    {
        bill = units * 1.5;
    }
    else if (units <= 200)
    {
        bill = (100 * 1.5) + (units - 100) * 2.5;
    }
    else if (units <= 300)
    {
        bill = (100 * 1.5) + (100 * 2.5) + (units - 200) * 4.0;
    }
    else
    {
        bill = (100 * 1.5) + (100 * 2.5) + (100 * 4.0) + (units - 300) * 6.0;
    }

    bill = bill + fixed_charge;

    printf("\n----- BILL DETAILS -----\n");
    printf("Consumer Number : %d\n", consumer_no);
    printf("Consumer Name   : %s\n", name);
    printf("Units Consumed  : %.2f\n", units);
    printf("Total Bill      : Rs. %.2f\n", bill);

    return 0;
}
